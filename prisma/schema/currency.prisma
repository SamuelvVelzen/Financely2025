// ----------
// Exchange rates (base-relative storage)
// ----------

model ExchangeRate {
  id           String   @id @default(cuid())
  currency     String
  rateToBase   Float
  baseCurrency String   @default("EUR")
  date         DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([currency, date, baseCurrency])
  @@index([date])
}
